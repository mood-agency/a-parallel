# Client dev server port (must match server CORS — same value in root .env for `bun run dev`)
# VITE_PORT=5173

# Host to bind the dev server (default: localhost, use 0.0.0.0 for remote access)
# VITE_HOST=localhost

# Backend server port (Vite proxy target). Must match the central server PORT (default 3001).
# VITE_SERVER_PORT=3001

# Full backend server URL (for production/deployed setups where the server is on a different host)
# When set, overrides VITE_SERVER_PORT for API and WebSocket connections.
# Example: VITE_SERVER_URL=https://funny-server.example.com
# VITE_SERVER_URL=

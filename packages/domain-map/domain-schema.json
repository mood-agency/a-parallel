{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://funny.dev/domain-schema/v1.json",
  "title": "Domain Map Strategic Design",
  "description": "Schema for domain.yaml — defines DDD strategic architecture (domains, subdomains, bounded contexts, context map, teams)",
  "type": "object",
  "required": ["domain", "subdomains"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to JSON Schema for editor validation"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Schema version"
    },
    "domain": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "The top-level domain name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the domain"
        }
      }
    },
    "subdomains": {
      "type": "object",
      "minProperties": 1,
      "description": "Each key is a subdomain name, value defines its strategic classification and bounded context",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "bounded-context"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["core", "supporting", "generic"],
            "description": "Strategic classification: core (competitive differentiator), supporting (essential but not unique), generic (off-the-shelf replaceable)"
          },
          "description": {
            "type": "string",
            "description": "What this subdomain does and why it exists"
          },
          "bounded-context": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*$",
            "description": "PascalCase identifier for the bounded context (used in context-map references)"
          },
          "aggregates": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Aggregate root names visible from this BC's public surface"
          },
          "publishes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*(:[a-z][a-z0-9_-]*)?$"
            },
            "description": "Domain events this BC publishes to the outside world"
          },
          "exposes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Public API surface (service methods) exposed to other BCs"
          }
        }
      }
    },
    "shared-kernel": {
      "type": "object",
      "required": ["name", "includes"],
      "additionalProperties": false,
      "description": "Infrastructure shared by all bounded contexts (DDD Shared Kernel pattern)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the shared kernel"
        },
        "description": {
          "type": "string",
          "description": "What the shared kernel provides"
        },
        "includes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Components included in the shared kernel"
        }
      }
    },
    "context-map": {
      "type": "array",
      "description": "Inter-BC relationships (the DDD Context Map)",
      "items": {
        "type": "object",
        "required": ["upstream", "downstream", "relationship"],
        "additionalProperties": false,
        "properties": {
          "upstream": {
            "type": "string",
            "description": "Bounded context name (the provider/supplier side)"
          },
          "downstream": {
            "type": "string",
            "description": "Bounded context name (the consumer/dependent side). Use \"*\" for all BCs."
          },
          "relationship": {
            "enum": [
              "customer-supplier",
              "partnership",
              "conformist",
              "published-language",
              "anti-corruption-layer",
              "open-host-service",
              "shared-kernel",
              "separate-ways"
            ],
            "description": "DDD strategic relationship type"
          },
          "upstream-role": {
            "enum": ["supplier", "customer"],
            "description": "Role of the upstream BC (for customer-supplier relationships)"
          },
          "downstream-role": {
            "enum": ["supplier", "customer"],
            "description": "Role of the downstream BC (for customer-supplier relationships)"
          },
          "via": {
            "type": "string",
            "description": "Intermediary component (e.g., SharedKernel.ThreadEventBus)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of this relationship"
          },
          "implemented-by": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Source-level implementation references (e.g., 'AgentRunner -> ThreadManager')"
          }
        }
      }
    },
    "teams": {
      "type": "object",
      "description": "Team ownership mapping — which team owns which bounded contexts",
      "additionalProperties": {
        "type": "object",
        "required": ["owns"],
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string",
            "description": "What this team is responsible for"
          },
          "owns": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Bounded context names owned by this team"
          },
          "contact": {
            "type": "string",
            "description": "Team contact (email, Slack channel, etc.)"
          }
        }
      }
    }
  }
}

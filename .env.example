# ──────────────────────────────────────────────────────────────
# Single .env for all packages (runtime, client, server)
# Copy to .env and uncomment/edit what you need.
# All values below show their defaults — you can omit unchanged ones.
# ──────────────────────────────────────────────────────────────

# ── Runtime (packages/runtime) ────────────────────────────────

# Server port
# PORT=3001

# Host to bind (use 0.0.0.0 for remote access)
# HOST=127.0.0.1

# Authentication mode: 'local' (single user) or 'multi' (multi-user with login)
# AUTH_MODE=local

# Database mode: 'sqlite' (default) or 'postgres' (required for multi-user)
# DB_MODE=sqlite

# PostgreSQL connection (required when DB_MODE=postgres or AUTH_MODE=multi)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Path to the Claude CLI binary (optional, auto-detected)
# CLAUDE_BINARY_PATH=/path/to/claude

# OpenTelemetry endpoint for observability (optional)
# OTLP_ENDPOINT=http://localhost:4000

# ── Client (packages/client) ─────────────────────────────────

# Client dev server port
# VITE_PORT=5173

# Client dev server host
# VITE_HOST=localhost

# Backend server port (for dev proxy)
# VITE_SERVER_PORT=3001

# Full backend URL (overrides VITE_SERVER_PORT; for deployed/team setups)
# VITE_SERVER_URL=http://localhost:3002

# OpenTelemetry endpoint for browser telemetry
# VITE_OTLP_ENDPOINT=http://localhost:4000

# ── Team mode (packages/server + runtime) ─────────────────────
# Only needed when running the central server for multi-user teams.

# Central server URL (tells the runtime to register with the server)
# TEAM_SERVER_URL=http://localhost:3002

# Shared secret between server and runtime (required when TEAM_SERVER_URL is set)
# RUNNER_AUTH_SECRET=<generate with: openssl rand -hex 32>

# Default runtime URL — server falls back to this when no runner is registered
# DEFAULT_RUNNER_URL=http://localhost:3001

# CORS origins for the central server (comma-separated)
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

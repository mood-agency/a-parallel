# ──────────────────────────────────────────────────────────────
# Single .env for all packages (runtime, client, server)
# Copy to .env and uncomment/edit what you need.
# All values below show their defaults — you can omit unchanged ones.
# ──────────────────────────────────────────────────────────────

# ── Server / Runtime ─────────────────────────────────────────

# Server port
# PORT=3001

# Host to bind (use 0.0.0.0 for remote access)
# HOST=127.0.0.1

# Log level: debug | info | warn | error
# LOG_LEVEL=info

# Data directory for DB, secrets, and encryption keys
# FUNNY_DATA_DIR=~/.funny

# Path to the Claude CLI binary (optional, auto-detected)
# CLAUDE_BINARY_PATH=/path/to/claude

# Disable native git module (falls back to CLI-based git)
# FUNNY_DISABLE_NATIVE_GIT=false

# ── Authentication ───────────────────────────────────────────

# Authentication mode: 'local' (single user) or 'multi' (multi-user with login)
# AUTH_MODE=local

# Better Auth secret (auto-generated if omitted; stored at ~/.funny/auth-secret)
# BETTER_AUTH_SECRET=

# Better Auth base URL (for OAuth callbacks)
# BETTER_AUTH_BASE_URL=http://localhost:3001

# Default admin credentials (created on first startup)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# ADMIN_EMAIL=admin@local.host

# ── Database ─────────────────────────────────────────────────

# Database mode: 'sqlite' (default) or 'postgres' (required for multi-user)
# DB_MODE=sqlite

# PostgreSQL connection (required when DB_MODE=postgres or AUTH_MODE=multi)
# Option 1: Full URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Option 2: Individual variables
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_NAME=funny

# ── Client (packages/client) ────────────────────────────────

# Client dev server port
# VITE_PORT=5173

# Client dev server host
# VITE_HOST=localhost

# Backend server port (for dev proxy)
# VITE_SERVER_PORT=3001

# Full backend URL (overrides VITE_SERVER_PORT; for deployed/team setups)
# VITE_SERVER_URL=

# OpenTelemetry endpoint for browser telemetry
# VITE_OTLP_ENDPOINT=http://localhost:4000

# ── AI / LLM ────────────────────────────────────────────────

# Anthropic API key (for SDK-based agent mode)
# ANTHROPIC_API_KEY=

# OpenAI API key (for alternative model provider)
# OPENAI_API_KEY=

# Ollama server URL (for local models)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# API timeout in milliseconds (default: 4 hours)
# API_TIMEOUT_MS=14400000

# ── GitHub ───────────────────────────────────────────────────

# GitHub OAuth App client ID (for "Clone from GitHub" feature)
# Create one at https://github.com/settings/applications/new (enable Device Flow)
# GITHUB_CLIENT_ID=

# GitHub personal access token (for push/PR operations in agent mode)
# GH_TOKEN=

# ── Team mode ────────────────────────────────────────────────
# Only needed when running the central server for multi-user teams.

# Central server URL (tells the runtime to register with the server)
# TEAM_SERVER_URL=http://localhost:3002

# Shared secret between server and runtime (required when TEAM_SERVER_URL is set)
# RUNNER_AUTH_SECRET=<generate with: openssl rand -hex 32>

# User invite token for self-service runner registration
# RUNNER_INVITE_TOKEN=

# Runner's publicly reachable HTTP URL (auto-detected if omitted)
# RUNNER_HTTP_URL=

# Disable the in-process local runner (remote-only mode)
# LOCAL_RUNNER=true

# Default runtime URL — server falls back to this when no runner is registered
# DEFAULT_RUNNER_URL=http://localhost:3001

# CORS origins for the central server (comma-separated)
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Email (SMTP) ────────────────────────────────────────────
# Optional — used for invite emails and notifications.

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Memory / Embeddings ─────────────────────────────────────
# Optional — for the semantic memory feature.

# Embedding provider: 'ollama' (default) or 'openai'
# MEMORY_EMBEDDING_PROVIDER=ollama

# Ollama embedding configuration
# MEMORY_OLLAMA_URL=http://localhost:11434
# MEMORY_OLLAMA_MODEL=nomic-embed-text

# Memory recall limit (max memories returned per query)
# MEMORY_RECALL_LIMIT=10

# Memory garbage collection interval (in minutes)
# MEMORY_GC_INTERVAL=10

# ── Observability ────────────────────────────────────────────

# OpenTelemetry collector endpoint
# OTLP_ENDPOINT=http://localhost:4000

# Enable debug mode for agents
# DEBUG_AGENT=1

# ── Webhook Ingestion ────────────────────────────────────────
# Optional — for receiving pipeline events from external agents.

# Shared secret for authenticating inbound webhooks
# INGEST_WEBHOOK_SECRET=

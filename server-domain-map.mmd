  %% Event flow
  Agent_Execution_agent_message_handler -- "git:changed" --> Git_Operations_git_status_handler
  Agent_Execution_agent_runner -- "agent:completed" --> Git_Operations_agent_completed_git_status_handler
  Agent_Execution_agent_runner -- "agent:completed" --> Agent_Execution_agent_completed_queue_handler
  Agent_Execution_agent_runner -- "agent:completed" --> Thread_Management_comment_handler
  Git_Operations_git_service -- "git:staged" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:unstaged" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:reverted" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:committed" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:pushed" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:pulled" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:merged" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:stashed" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:stash-popped" --> Git_Operations_git_event_persistence_handler
  Git_Operations_git_service -- "git:reset-soft" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "agent:completed" --> Git_Operations_agent_completed_git_status_handler
  Shared_Kernel_thread_event_bus -- "agent:completed" --> Agent_Execution_agent_completed_queue_handler
  Shared_Kernel_thread_event_bus -- "agent:completed" --> Thread_Management_comment_handler
  Shared_Kernel_thread_event_bus -- "git:changed" --> Git_Operations_git_status_handler
  Shared_Kernel_thread_event_bus -- "git:committed" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:pushed" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:merged" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:staged" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:unstaged" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:reverted" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:pulled" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:stashed" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:stash-popped" --> Git_Operations_git_event_persistence_handler
  Shared_Kernel_thread_event_bus -- "git:reset-soft" --> Git_Operations_git_event_persistence_handler

